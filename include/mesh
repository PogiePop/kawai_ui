#ifndef KAWAI_MESH
#define KAWAI_MESH
#include <glad/glad.h>
#include <glm/glm.hpp>
#include <shader>

namespace Kawai
{

    class Font;
    enum Align;
    
    // 暂时不加入纹理
    struct Vertex
    {
        glm::vec2 position;
        glm::vec2 texCoord;
        glm::vec4 color;
    };

    class Mesh
    {
    public:
        Mesh() {
            if (!glfwGetCurrentContext())return;
            glGenVertexArrays(1, &vao);
            glGenBuffers(1, &vbo);
            glGenBuffers(1, &ebo);
        }
        Mesh(const std::vector<Vertex> &vertices, const std::vector<GLuint> &indices)
            : vertices(vertices), indices(indices)
        {
            if (!glfwGetCurrentContext())return;
            init(vertices, indices);
        }

        GLuint vao = 0, vbo = 0, ebo = 0;
        std::vector<Vertex> vertices;
        std::vector<GLuint> indices;

    private:
        void init(const std::vector<Vertex> &vertices, const std::vector<GLuint> &indices);
    };

    Mesh CreateUIRectMesh(float x, float y, float w, float h);

    void ModifyUIRectMesh(Mesh &mesh, float x, float y, float w, float h);
    Mesh CreateUnitQuad();
}

#endif