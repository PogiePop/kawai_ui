namespace Kawai
{
    class Event;
    class UIFocusEvent;
    class UIBlurEvent;
    class UIWindow;
    enum ComponentType
    {
        Rect,
        Panel,
        Button,
        Text,
        TextBox
    };

#define COMPONENT_TYPE_DEF(type)                                                        \
    static ComponentType GetStaticType() { return ComponentType::type; }                \
    virtual ComponentType GetComponentType() const override { return GetStaticType(); } \
    virtual const char *GetTypeName() const override { return #type; }

    class UIComponent
    {
    public:
        UIComponent(float x, float y, float w, float h, int priority = 0, bool visible = true)
            : x(x), y(y), w(w), h(h), priority(priority), visible(visible)
        {
            TransformToNDCP();
        }

        virtual void InitMesh();
        

        void TransformToNDCP();
        

        virtual ComponentType GetComponentType() const = 0;
        virtual const char* GetTypeName() const = 0;
        virtual void render() = 0;
        virtual bool IsPointInside(float x, float y);
        

        void SetPriority(int order);

        virtual ~UIComponent() = default;
        glm::vec2 toNDC(const glm::vec2& p);
        
        float toNDCSizeHorizontal(float x);
        
        float toNDCSizeVertical(float y);
        
        int GetScreenWidth() const { return UIRender::GetInstance().GetScreenWidth(); }
        int GetScreenHeight() const { return UIRender::GetInstance().GetScreenHeight(); }

        void SetShader(Shader* sd)
        {
            ui_shader = sd;
        }

        void UpdateComponentSize();
        

        template <std::derived_from<UIComponent> T>
        void AddChildComponent(T* child);

        void AttachToWindow(UIWindow* window);

        glm::vec2 GetWorldPos() const;
        

        // 事件处理
        virtual bool OnEvent(Event& event) = 0;

        float x, y, ndc_x, ndc_y, ndc_w, ndc_h;
        float w, h;
        int priority;
        bool visible;
        Shader* ui_shader = nullptr;
        Mesh ui_mesh;
        // layout类还没写暂留
        std::vector<UIComponent*> childrens;
        UIComponent* parent = nullptr;
        bool childChange = false;
        UIWindow* m_Window = nullptr;
        std::string name;
        GLuint number;
        bool focused = false;
        int renderID;

        float ui_scale = 1.0f;
    };

    // rect
    class UIRect : public UIComponent
    {
    public:
        UIRect(float x, float y, float w, float h, glm::vec4 color = glm::vec4(1.0f, 1.0f, 1.0f, 1.0f))
            : UIComponent(x, y, w, h), color(color)
        {
        }
        void render() override;
        bool OnEvent(Event& event) override;
        COMPONENT_TYPE_DEF(Rect)
            ~UIRect() = default;

    private:
        glm::vec4 color;
    };

    // panel
    class UIPanel : public UIComponent
    {
    public:
        UIPanel(float x, float y, float w, float h,
            glm::vec4 color = glm::vec4(1.0f, 1.0f, 1.0f, 1.0f),
            float radius = 50.0f)
            : UIComponent(x, y, w, h), bgColor(color), radius(radius)
        {
            ndc_radius = radius / std::min(GetScreenWidth(), GetScreenHeight()) * 2.0f;
        }
        bool OnEvent(Event& event) override;
        ~UIPanel() = default;
        COMPONENT_TYPE_DEF(Panel)
            void render() override;

    private:
        glm::vec4 bgColor;
        float radius, ndc_radius;
    };

    // Button
    class UIButton : public UIComponent
    {
    public:
        UIButton(float x, float y, int w, int h, float radius = 50.0f)
            : UIComponent(x, y, w, h), radius(radius)
        {
            ndc_radius = radius / std::min(GetScreenWidth(), GetScreenHeight()) * 2.0f;
            this->currentColor = commonColor;
        }

        enum ButtonStatus
        {
            Common,
            Hover,
            Click
        };

        ~UIButton() = default;
        COMPONENT_TYPE_DEF(Button)

            void render() override;
        bool OnEvent(Event& event) override;

        void update(float deltatime);

        using Onclick = std::function<void(void)>;
        using OnBlur = std::function<void(UIBlurEvent&)>;
        using OnFocus = std::function<void(UIFocusEvent&)>;


        void SetOnclick(const Onclick& onclick) { this->click = onclick; }
        void SetOnFoucs(const OnFocus& onfoucs) { this->focus = onfoucs; }
        void SetOnBlur(const OnBlur& onblur) { this->blur = onblur; }
        void SetCommonColor(const glm::vec4& color) { this->commonColor = color; }
        void SetHoverColor(const glm::vec4& color) { this->hoverColor = color; }
        void SetClickColor(const glm::vec4& color) { this->clickColor = color; }

    private:
        glm::vec4 commonColor = normal_btn_color;
        glm::vec4 hoverColor = hover_btn_color;
        glm::vec4 clickColor = click_btn_color;
        float radius, ndc_radius;
        ButtonStatus state = Common;
        bool enableShadow = true;
        glm::vec2 shadowOffset = { 0.02f, -0.02f };
        float shadowBlur = 0.04f;
        glm::vec4 shadowColor = { 0.0f, 0.0f, 0.0f, 0.3f };

        glm::vec4 currentColor;

        // animation
        float scale = 1.0f;
        const float scaleNormal = 1.0f;
        const float scaleHover = 1.02f;
        const float scaleClick = 0.96f;

        Onclick click;
        OnFocus focus;
        OnBlur blur;
    };

    //对齐方式
    enum Align
    {
        TOP_LEFT,
        TOP_CENTER,
        TOP_RIGHT,
        MIDDLE_LEFT,
        CENTER,
        MIDDLE_RIGHT,
        BOTTOM_LEFT,
        BOTTOM_CENTER,
        BOTTOM_RIGHT
    };


    class UIText : public UIComponent
    {
    public:
        COMPONENT_TYPE_DEF(Text)
            UIText(float x, float y, float w, float h, Font* font, const std::string& text, Align align = CENTER, uint32_t fontsize = 16) :
            UIComponent(x, y, w, h), m_Font(font), m_FontSize(fontsize), m_Text(text), m_Align(align)
        {
            //m_ContentSize = { 2 * (float)w * ui_scale / 3, 2 * (float)h * ui_scale / 3 };
            //std::println("init:{}X{}", m_ContentSize.x, m_ContentSize.y);
        }

        void render();
        bool OnEvent(Event& event) override;

        void InitMesh() override;

        void SetFontShader(Shader* sd) { this->m_FontShader = sd; }

        void CalculateFitFontSize();
        float CalculateAlignX(float lineW);
        float CalculateAlignY(float totalH);
        glm::vec2 GetLineMetrics(const std::string& line, float scale);
        float GetLineHeight(float scale = 1.0f);
        float GetTotalLineHeight(float scale = 1.0f);
        void SplitTextIntoLines(float scale);
        void UpdateInnerSpacing();
        void DrawLine(float x, float y, const std::string& line, float scale);
        void SetFontColor(const glm::vec4& color) { this->color = color; }
        void SetFontAlign(const Align& align) { this->m_Align = align; UpdateInnerSpacing(); }

    protected:
        Shader* m_FontShader = nullptr;
        Mesh m_FontMesh;
        Font* m_Font = nullptr;
        glm::vec4 color = white;
        glm::vec4 bgColor = green;
        uint32_t m_FontSize;
        uint32_t m_FitFontSize;//适配后的字符大小
        std::string m_Text;
        Align m_Align;
        float m_letterSpacing = 0.0f; //字符间距
        float m_lineSpacing = 0.0f; //行间距
        std::vector<std::string> m_lines; //存储每行字符串

        //内边距
        float m_leftSpacing = 0.0f;
        float m_rightSpacing = 0.0f;
        float m_topSpacing = 0.0f;
        float m_bottomSpacing = 0.0f;
        glm::vec2 m_ContentSize = { 0.0f, 0.0f };

    };


    class UITextBox : public UIText
    {
    public:
        UITextBox(float x, float y, float w, float h, const std::string& placeholder = "", Align align = MIDDLE_LEFT, uint32_t fontSize = 16, Font* font = nullptr)
        :UIText(x, y, w, h, font, "", align, fontSize)
        , placeholder(placeholder){ }
        COMPONENT_TYPE_DEF(TextBox)
        void render() override;
        bool OnEvent(Event& e) override;
        void InitMesh() override;
    private:
        void UpdateCursorBlink();//更新光标闪烁动画
        void DrawCursor();//绘制光标

    private:
        glm::vec4 m_FocusBgColor = { 1.0f, 1.0f, 1.0f, 1.0f };
        glm::vec4 m_BorderColor = { 0.75f, 0.75f, 0.75f, 1.0f };
        glm::vec4 m_PlaceholderColor = { 0.5f, 0.5f, 0.5f, 1.0f };
        std::string placeholder;
        // 光标
        float m_CursorTimer = 0.0f;
        bool m_CursorVisible = true;
        int m_CursorPos = 0;

