#ifndef KAWAI_EVENT_MOUSE
#define KAWAI_EVENT_MOUSE

#include <event/event>

namespace Kawai
{
    class MouseEvent : public Event
    {
        public:
            EventCategory_DEF(EventCategoryMouse)
            virtual ~MouseEvent() = default; 
    };
    
    class MouseMoveEvent : public MouseEvent
    {
        public:
            //鼠标位置(x, y)
            double x, y;
            EventType_DEF(MouseMove)
            MouseMoveEvent(double x, double y):x(x), y(y){}
    };

    class MouseScrollEvent : public MouseEvent
    {
        public:
            //鼠标偏移距离
            double xOffset, yOffset;
            EventType_DEF(MouseScroll)
            MouseScrollEvent(double xOffset, double yOffset): xOffset(xOffset), yOffset(yOffset){}
    };

    class MouseButtonEvent : public MouseEvent
    {
        public:
            //按下的按键
            int button;
            virtual ~MouseButtonEvent() = 0;
    };

    class MouseButtonPressEvent : public MouseButtonEvent
    {
        public:
            EventType_DEF(MouseButtonPress)
            MouseButtonPressEvent(int btn){ this->button = btn; }
    };

    class MouseButtonReleaseEvent : public MouseButtonEvent
    {
        public:
            EventType_DEF(MouseButtonRelease)
            MouseButtonReleaseEvent(int btn){ this->button = btn; }
    };
}

#endif