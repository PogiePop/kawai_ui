#ifndef KAWAI_UI_RENDER
#define KAWAI_UI_RENDER

#include <glad/glad.h>
#include <glm/glm.hpp>

namespace Kawai
{
    class UIRender
    {
        public:
            void init(int width, int height);
            void DrawArrays(GLenum mode, GLuint vao, size_t vertexCount);
            void DrawElements(GLenum mode, GLuint vao, size_t indexCount);
            static UIRender& GetInstance(){ static UIRender render;  ;return render; }
            int GetScreenWidth()const { return screenWidth; }
            int GetScreenHeight()const{ return screenHeight; }
            void SetScW(int w){ this->screenWidth = w;}
            void SetScH(int h){ this->screenHeight = h; }
        private:
            UIRender() = default;
            int screenWidth, screenHeight;
            float aspect;
            //static UIRender render;
    };
}


#endif