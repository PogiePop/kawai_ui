#ifndef KAWAI_UI_WINDOW
#define KAWAI_UI_WINDOW
#include <ui_render>
#include <ui_component>
#include <map>

namespace Kawai
{
    struct SortKey
    {
        int order;
    };

    class UIWindow
    {
    public:
        UIWindow(int w, int h, const std::string &title)
            : w(w), h(h), title(title)
        {
            init(w, h, title);
            this->defaultUIShader = new Shader("shaders/ui.vert", nullptr, "shaders/ui.frag");
            this->radiusShader = new Shader("shaders/ui.vert", nullptr, "shaders/ui_radius.frag");
            this->btnShader = new Shader("shaders/ui.vert", nullptr, "shaders/ui_btn.frag");
            this->textShader = new Shader("shaders/ui_text.vert", nullptr, "shaders/ui_text.frag");
            Font* det = new Font();
            det->load("fonts/BRADHITC.TTF", 64);
            ui_fonts["default"] = det;
        }

        using WindowFrameSizeCallback = std::function<void(GLFWwindow*, int, int)>;
        using CursorMoveCallback = std::function<void(GLFWwindow*, double, double)>;
        using MouseButtonPressCallback = std::function<void(GLFWwindow*, int, int, int)>;
        using MouseButtonReleaseCallback = std::function<void(GLFWwindow*, int, int, int)>;

        ~UIWindow();

        void OnUpdate();

        void OnRender();

        void OnEvent(Event& e);

        void SetWindowColor(const glm::vec4 &color) { this->color = color; }

        std::map<std::string, Font*>& GetFontResources(){ return this->ui_fonts; }

        template <std::derived_from<UIComponent> T>
        void AddComponent(T *comp)
        {
            comp->InitMesh();
            switch (comp->GetComponentType())
            {
            case Rect:
                comp->SetShader(this->defaultUIShader);
                break;
            case Panel:
                comp->SetShader(this->radiusShader);
                break;
            case Button:
                comp->SetShader(this->btnShader);
                break;
            case Text:
            {
                ((UIText*)comp)->SetFontShader(this->textShader);
                comp->SetShader(this->defaultUIShader);
            }  
                break;
            default:
                break;
            }
            comp->AttachToWindow(this);
            this->ui_components.push_back(comp);
            AddComponentCount();
        }

        bool needSort = false;
        bool needResize = false;
        bool uiNumChange = false;
        int instanceID = 0;
        int componentNum = 0;

        void AddComponentCount()
        {
            uiNumChange = true;
            this->componentNum++;
        }
        Shader* textShader;
    private:
        void UpdateComponent(UIComponent *comp);
        void CollectComponent(UIComponent *comp, std::vector<UIComponent *> &queue);

    private:
        void init(int w, int h, const std::string &title);
        std::string title;
        int w, h;
        glm::vec4 color = glm::vec4(0.1f, 0.2f, 0.3f, 1.0f);
        std::vector<UIComponent *> ui_components;
        std::vector<UIComponent* >ui_eventQ;//按照覆盖层遍历，越上面的ui越容易捕获事件
        std::vector<UIComponent* >ui_renderQ;//渲染队列
        std::map<std::string, Font*>ui_fonts;
        // std::vector<UIComponent*> comp_queue;
        // UIRender ui_render;
        GLFWwindow *window;
        Shader *defaultUIShader;
        Shader *radiusShader;
        Shader *btnShader;
        
        WindowFrameSizeCallback m_SizeCall;
        CursorMoveCallback m_CursorCall;
        MouseButtonPressCallback m_MSPressCall;
        MouseButtonReleaseCallback m_MSReleaseCall;
    };
}

#endif